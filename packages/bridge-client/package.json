{
	"type": "module",
	"name": "@gajae-code/bridge-client",
	"version": "0.11.8",
	"description": "Transport-only v3 SDK WebSocket client",
	"homepage": "https://gajae-code.com",
	"author": "Yeachan-Heo and Gajae Code Contributors",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Yeachan-Heo/gajae-code.git",
		"directory": "packages/bridge-client"
	},
	"bugs": {
		"url": "https://github.com/Yeachan-Heo/gajae-code/issues"
	},
	"keywords": [
		"sdk",
		"websocket",
		"transport",
		"client"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsc -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	}
}
